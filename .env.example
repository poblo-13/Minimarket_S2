# copia este archivo como .env y completa los valores
# la clave debe tener minimo 32 caracteres (256 bits), requisito de HS256
JWT_SECRET=cambia-esto-por-una-clave-larga-y-secreta-minimo-32-chars
JWT_EXPIRATION=3600000

# contraseñas iniciales que siembra DataSeeder.java (se hashean con BCrypt al arrancar)
SEED_ADMIN_PASSWORD=12345
SEED_EMPLEADO_PASSWORD=12345
SEED_CLIENTE_PASSWORD=12345
